    "7_wiring_for_hybrid_systems": {
      "standard": "EN 50131 / Manufacturer",
      "principle": "Wired zones use 4-core alarm cable from panel to detector",
      "cable_specifications": {
        "detector_cable": "4-core 0.22mm\u00b2 alarm cable (2 cores signal + 2 cores power/tamper)",
        "siren_cable": "2-core 1.0mm\u00b2 (for powered sirens)",
        "rs485_bus": "Shielded twisted pair 0.5mm\u00b2, max 1200m, for keypads and expansion modules",
        "max_detector_run_m": 300,
        "eol_resistor": "Required: End-of-line resistor on each wired zone (typically 2.2k\u03a9 or 4.7k\u03a9 as per panel spec)"
      },
      "zone_types": {
        "NC": "Normally Closed \u2014 most common for magnetic contacts and PIRs",
        "NO": "Normally Open \u2014 used for some sensors",
        "EOL": "End-of-Line resistor \u2014 required for tamper detection per EN 50131 Grade 2+",
        "DEOL": "Double EOL \u2014 required for Grade 3 (distinguishes alarm, tamper, and fault)"
      }
    },
