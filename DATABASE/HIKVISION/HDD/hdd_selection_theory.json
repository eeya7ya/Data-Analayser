    "6_performance_considerations": {
      "standard": "System Design",
      "principle": "HDD speed must support total write throughput from all cameras",
      "rpm_guide": {
        "5400rpm": {
          "sustained_write_mbps": 110,
          "max_cameras_recording": "Up to 32 at 4MP H.265",
          "best_for": "Standard surveillance, 1-4 bay NVRs"
        },
        "7200rpm": {
          "sustained_write_mbps": 180,
          "max_cameras_recording": "Up to 64 at 4MP H.265",
          "best_for": "High camera count, AI analytics, 4K recording"
        }
      },
      "ai_workload": "AI NVRs perform simultaneous write (recording) + random read (analytics/search). Standard surveillance HDDs may bottleneck. Use AI-grade (DS200HKAI or WD Purple Pro) for DeepinMind NVRs."
    },
    "7_hdd_health_monitoring": {
      "standard": "S.M.A.R.T. / WD Device Analytics",
      "principle": "Monitor HDD health proactively to replace before failure",
      "monitoring": {
        "smart": {
          "description": "Self-Monitoring, Analysis and Reporting Technology",
          "metrics": [
            "Reallocated sectors",
            "Spin retry count",
            "Temperature",
            "Power-on hours",
            "Pending sectors"
          ],
          "access": "Via NVR HDD management page"
        },
        "wdda": {
          "description": "WD Device Analytics (WD Purple only)",
          "metrics": [
            "Workload analysis",
            "Temperature trending",
            "Remaining life estimate",
            "Vibration impact"
