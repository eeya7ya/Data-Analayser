        }
      },
      "recommendation": "For standard Hikvision systems: either brand works. For AI/DeepinMind NVRs with heavy analytics: HikStorage AI (DS200HKAI) or WD Purple Pro."
    },
    "4_multi_bay_configuration": {
      "standard": "System Design",
      "principle": "Multiple HDDs provide more storage and optional redundancy",
      "strategies": [
        {
          "config": "Single HDD",
          "redundancy": "None",
          "risk": "Total data loss if HDD fails",
          "best_for": "1-8 cameras, budget systems"
        },
        {
          "config": "Multiple HDDs (JBOD)",
          "redundancy": "None \u2014 each HDD stores sequentially",
          "risk": "Partial data loss (only affected HDD's recordings)",
          "best_for": "Most surveillance \u2014 NVR fills HDDs sequentially or by group"
        },
        {
          "config": "RAID 1 (Mirror)",
          "redundancy": "Full mirror \u2014 50% usable capacity",
          "risk": "Survives 1 HDD failure",
          "best_for": "Critical recordings, small systems needing redundancy"
        },
        {
          "config": "RAID 5",
          "redundancy": "Distributed parity \u2014 loses 1 HDD capacity",
          "risk": "Survives 1 HDD failure",
          "best_for": "Enterprise NVRs (9600 series), balance of capacity and safety"
        },
        {
          "config": "RAID 6",
          "redundancy": "Dual parity \u2014 loses 2 HDD capacity",
          "risk": "Survives 2 simultaneous HDD failures",
          "best_for": "Mission-critical, 24-bay enterprise systems"
        }
      ],
      "nvr_raid_support": "RAID is available only on enterprise NVRs (DS-96xx series with /R suffix). Standard NVRs use JBOD."
    },
