          "typical_config": "4\u00d7 8TB or 4\u00d7 10TB"
        },
        {
          "nvr_bays": 8,
          "max_per_hdd_tb": 10,
          "total_max_tb": 80,
          "typical_config": "8\u00d7 8TB or 8\u00d7 10TB"
