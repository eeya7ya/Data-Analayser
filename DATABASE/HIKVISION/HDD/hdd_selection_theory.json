  "selection_criteria": {
    "1_surveillance_vs_desktop_hdd": {
      "standard": "Manufacturer / Application",
      "principle": "Surveillance-grade HDDs are engineered for 24/7 continuous write with multiple streams",
      "comparison": [
        {
          "type": "Desktop HDD (WD Blue/Seagate Barracuda)",
          "duty_cycle": "8\u00d75 (office hours)",
          "streams": "1-2",
          "workload_tb_year": 55,
          "firmware": "Desktop optimized",
          "vibration": "No vibration compensation",
          "warranty": "2 years",
          "use_in_nvr": "NOT recommended \u2014 will fail prematurely"
        },
        {
          "type": "Surveillance HDD (WD Purple/HikStorage V)",
          "duty_cycle": "24\u00d77",
          "streams": "Up to 64",
          "workload_tb_year": 180,
          "firmware": "AllFrame technology \u2014 reduces frame drops",
          "vibration": "3D Active Balance Plus (WD) for multi-bay",
          "warranty": "3 years",
          "use_in_nvr": "DESIGNED for this purpose"
        },
        {
          "type": "AI/Enterprise HDD (HikStorage AI/WD Purple Pro)",
          "duty_cycle": "24\u00d77 intensive",
          "streams": "64+ with AI analytics",
          "workload_tb_year": 360,
          "firmware": "Optimized for simultaneous record + AI read",
          "vibration": "Enhanced vibration compensation",
          "warranty": "3-5 years",
          "use_in_nvr": "For AcuSense/DeepinMind NVRs with heavy analytics"
        }
      ],
      "rule": "NEVER use desktop HDDs in surveillance recorders. Always use surveillance-grade (Purple or HikStorage V/AI series)."
    },
    "2_capacity_calculation": {
      "standard": "System Design",
      "principle": "HDD capacity must hold required days of recording at specified quality",
      "formula": {
        "storage_gb": "channels \u00d7 bitrate_mbps \u00d7 3600 \u00d7 recording_hours_per_day \u00d7 retention_days / 8 / 1024",
        "simplified": "channels \u00d7 daily_storage_gb \u00d7 retention_days"
      },
      "daily_storage_per_channel_gb": {
        "2MP_H265_24hr": 8,
        "4MP_H265_24hr": 16,
        "5MP_H265_24hr": 20,
        "8MP_H265_24hr": 35,
        "2MP_H264_24hr": 16,
        "4MP_H264_24hr": 32,
        "8MP_H264_24hr": 70
      },
      "examples": [
        {
          "scenario": "4ch \u00d7 2MP H.265, 30 days",
          "calculation": "4 \u00d7 8 \u00d7 30 = 960 GB",
          "recommended": "1 TB"
        },
        {
          "scenario": "8ch \u00d7 4MP H.265, 30 days",
          "calculation": "8 \u00d7 16 \u00d7 30 = 3,840 GB",
          "recommended": "4 TB"
        },
        {
          "scenario": "16ch \u00d7 4MP H.265, 30 days",
          "calculation": "16 \u00d7 16 \u00d7 30 = 7,680 GB",
          "recommended": "8 TB"
        },
        {
          "scenario": "32ch \u00d7 4MP H.265, 30 days",
          "calculation": "32 \u00d7 16 \u00d7 30 = 15,360 GB",
          "recommended": "2 \u00d7 8 TB"
        },
        {
          "scenario": "16ch \u00d7 8MP H.265, 30 days",
          "calculation": "16 \u00d7 35 \u00d7 30 = 16,800 GB",
          "recommended": "2 \u00d7 10 TB"
        },
        {
          "scenario": "64ch \u00d7 4MP H.265, 30 days",
          "calculation": "64 \u00d7 16 \u00d7 30 = 30,720 GB",
          "recommended": "4 \u00d7 8 TB"
        }
      ],
      "retention_guidelines": {
        "residential": "7-14 days typical",
        "small_commercial": "14-30 days",
        "enterprise": "30-90 days",
        "banking_finance": "90-180 days (regulatory)",
        "government_critical": "90-365 days (policy dependent)"
      }
    },
    "3_wd_purple_vs_hikstorage": {
      "standard": "Product Comparison",
      "principle": "Both are surveillance-grade. Selection based on availability, price, and NVR compatibility.",
      "comparison": {
        "wd_purple": {
          "brand": "Western Digital",
          "firmware": "AllFrame AI (8TB+)",
          "vibration": "3D Active Balance Plus",
          "ecosystem": "Universal \u2014 works in any SATA NVR/DVR",
          "health_monitoring": "WD Device Analytics (WDDA) via NVR"
        },
        "hikstorage_v": {
          "brand": "Hikvision",
          "firmware": "Surveillance optimized",
          "vibration": "Vibration compensation",
          "ecosystem": "Optimized for Hikvision recorders",
          "health_monitoring": "S.M.A.R.T. via Hikvision NVR"
        },
        "hikstorage_ai": {
          "brand": "Hikvision",
          "firmware": "AI workload optimized",
          "vibration": "Enhanced",
          "ecosystem": "Best for DeepinMind / AcuSense NVRs",
          "health_monitoring": "S.M.A.R.T.",
