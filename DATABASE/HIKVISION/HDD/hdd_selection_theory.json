    "8_environmental_and_vibration": {
      "standard": "Manufacturer / Installation",
      "principle": "HDDs in multi-bay NVRs experience vibration from adjacent drives",
      "vibration_mitigation": {
        "wd_purple": "3D Active Balance Plus \u2014 compensates for multi-drive vibration",
        "hikstorage": "Built-in vibration compensation",
        "installation_tips": [
          "Use rubber HDD mounting grommets if provided",
          "Ensure NVR is on stable, vibration-free surface",
          "Avoid stacking NVRs directly",
          "Keep NVR away from heavy machinery vibration sources"
        ]
      },
      "temperature": {
        "operating_range_c": {
          "min": 0,
          "max": 65
        },
        "optimal_c": {
          "min": 25,
          "max": 45
        },
        "note": "Every 10\u00b0C above 40\u00b0C approximately halves HDD lifespan. Ensure adequate ventilation around NVR."
      }
    },
    "9_cost_optimization": {
      "standard": "Design Best Practice",
      "principle": "Balance capacity, redundancy, and budget",
      "strategies": [
        {
          "strategy": "Use H.265+ compression",
          "savings": "50-75% storage reduction vs H.264",
          "implementation": "Enable H.265+ on all Hikvision cameras and NVR"
        },
        {
          "strategy": "Motion-only recording",
          "savings": "50-80% vs continuous",
          "implementation": "Record on motion/event only \u2014 reduces writes dramatically"
        },
        {
          "strategy": "Sub-stream recording",
          "savings": "70-90% vs main stream",
          "implementation": "Record sub-stream for non-critical cameras, main stream for key cameras"
        },
        {
          "strategy": "ANR (Automatic Network Replenishment)",
          "savings": "Protects against NVR downtime",
          "implementation": "Camera records to SD card during network outage, syncs to NVR on recovery"
        },
        {
          "strategy": "Right-size HDD",
          "savings": "Avoid over-provisioning",
          "implementation": "Calculate actual storage need (formula above) + 20% margin. Don't buy 10TB when 4TB suffices."
        }
      ]
    },
