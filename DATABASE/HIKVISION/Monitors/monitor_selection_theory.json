{
  "database_info": {
    "name": "Monitor Selection Theory - Standards Based",
    "version": "1.0",
    "purpose": "Engineering design tool for monitor selection based on international standards",
    "last_updated": "2026-04-05"
  },
  "selection_criteria": {
    "1_screen_size_selection": {
      "standard": "ISO 11064-5 / SMPTE EG 18",
      "principle": "Screen size is determined by viewing distance and content type, not preference",
      "formulas": {
        "min_viewing_distance": {
          "formula": "D_min = 1.5 \u00d7 screen_diagonal",
          "unit": "same as diagonal",
          "source": "ISO 11064-5:2008"
        },
        "max_viewing_distance_fhd": {
          "formula": "D_max = 3.2 \u00d7 screen_diagonal",
          "unit": "same as diagonal",
          "source": "SMPTE EG 18",
          "note": "For 1080p content where detail recognition is needed"
        },
        "max_viewing_distance_4k": {
          "formula": "D_max = 1.5 \u00d7 screen_diagonal",
          "unit": "same as diagonal",
          "source": "ITU-R BT.2020",
          "note": "4K allows closer viewing without pixel visibility"
        },
        "optimal_viewing_angle": {
          "formula": "Viewing angle = 2 \u00d7 arctan(screen_width / (2 \u00d7 distance))",
          "recommended_range_deg": {
            "min": 20,
            "max": 40
          },
          "source": "SMPTE EG 18 / THX"
        }
      },
      "lookup_table": [
        {
          "screen_inch": 19,
          "diagonal_mm": 483,
          "min_distance_mm": 724,
          "max_distance_fhd_mm": 1545,
