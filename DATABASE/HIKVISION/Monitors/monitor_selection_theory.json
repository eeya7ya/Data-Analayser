    "2_resolution_selection": {
      "standard": "ISO 9241-303 / EN 50132-7",
      "principle": "Resolution must match viewing distance and content detail requirements",
      "rules": {
        "surveillance_cctv": {
          "standard": "EN 50132-7 / BS EN 62676-4",
          "rule": "Minimum 1:1 pixel mapping per camera channel displayed",
          "requirements": {
            "single_camera_full_screen": "Monitor resolution >= camera resolution",
            "4_camera_split": "Monitor resolution >= 2x camera H-res \u00d7 2x camera V-res",
            "9_camera_split": "Monitor resolution >= 3x camera H-res \u00d7 3x camera V-res",
            "16_camera_split": "4K monitor required for HD cameras"
          }
        },
        "ppi_by_application": [
          {
            "application": "Surveillance spot monitor",
            "min_ppi": 40,
            "recommended_ppi": 60,
            "note": "Lower PPI acceptable at longer distance"
          },
          {
            "application": "Operator workstation",
            "min_ppi": 72,
            "recommended_ppi": 92,
            "note": "Text readability critical"
          },
          {
            "application": "Control room overview",
            "min_ppi": 50,
            "recommended_ppi": 70,
            "note": "Content viewed from 2-4m"
          },
          {
            "application": "Design review / CAD",
            "min_ppi": 92,
            "recommended_ppi": 110,
            "note": "Fine detail recognition"
          },
          {
            "application": "Public information display",
            "min_ppi": 30,
            "recommended_ppi": 50,
            "note": "Large text, viewed from 3-10m"
          }
        ],
        "resolution_vs_size_guideline": [
          {
            "size_range": "18-24 inch",
            "recommended": "FHD 1920x1080",
            "reason": "PPI 92-102, ideal for close viewing"
          },
          {
            "size_range": "27-32 inch",
            "recommended": "FHD or QHD",
            "reason": "FHD PPI drops to 56-82, QHD preferred for text"
          },
          {
            "size_range": "43+ inch",
            "recommended": "4K UHD 3840x2160",
            "reason": "FHD PPI below 52, pixel visible at operator distance"
          },
          {
            "size_range": "43+ inch surveillance",
            "recommended": "FHD acceptable",
            "reason": "If viewed from >2m and showing multiple cameras"
          }
        ]
      }
    },
    "3_brightness_contrast_selection": {
      "standard": "ISO 9241-307:2008 / ISO 3664:2009",
      "principle": "Brightness must overcome ambient light; contrast must ensure readability",
      "requirements": {
        "luminance_by_ambient": [
          {
            "ambient_lux": "< 50 (dark room)",
            "min_brightness_cdm2": 100,
            "recommended_cdm2": 150,
            "application": "Dedicated control room, dark NOC"
          },
          {
            "ambient_lux": "50-150 (dim room)",
            "min_brightness_cdm2": 150,
            "recommended_cdm2": 250,
            "application": "Control room with controlled lighting"
          },
          {
            "ambient_lux": "150-300 (office)",
            "min_brightness_cdm2": 250,
            "recommended_cdm2": 350,
            "application": "Standard office, reception"
          },
          {
            "ambient_lux": "300-500 (bright office)",
            "min_brightness_cdm2": 350,
            "recommended_cdm2": 500,
            "application": "Open plan office, retail back-office"
          },
          {
            "ambient_lux": "> 500 (daylight)",
            "min_brightness_cdm2": 500,
            "recommended_cdm2": 700,
            "application": "Public display, window-facing"
          }
        ],
        "contrast_ratio": {
          "standard": "ISO 9241-307",
          "minimum": "3:1 for text readability",
          "recommended": "5:1 for comfortable prolonged use",
          "ideal": "> 1000:1 for image-critical applications",
          "note": "Specified contrast is measured in dark room. Effective contrast degrades with ambient light."
        },
        "luminance_uniformity": {
          "standard": "ISO 9241-307",
          "requirement": ">= 75% (L_min / L_max across screen)",
          "note": "Critical for video walls and side-by-side displays"
        }
      }
    },
    "4_panel_type_selection": {
      "standard": "Manufacturer / Application Best Practice",
      "principle": "Panel technology determines viewing angle, color accuracy, contrast, and response",
      "comparison": [
        {
          "type": "VA (Vertical Alignment)",
          "viewing_angle": "178\u00b0 typical",
          "contrast": "3000:1 - 5000:1 native",
          "color_accuracy": "Good",
          "response_time": "6-8 ms typical",
          "best_for": "Surveillance, control rooms, 24/7 operation",
          "weakness": "Slight color shift at extreme angles",
          "note": "Best balance for CCTV - high contrast shows dark scenes better"
        },
        {
          "type": "IPS (In-Plane Switching)",
          "viewing_angle": "178\u00b0 with minimal color shift",
          "contrast": "1000:1 native",
          "color_accuracy": "Excellent",
          "response_time": "4-5 ms typical",
          "best_for": "Design review, color-critical work, multi-viewer stations",
          "weakness": "Lower contrast, potential IPS glow in dark rooms",
          "note": "Better color consistency across wide angles"
        },
        {
          "type": "TN (Twisted Nematic)",
          "viewing_angle": "90-170\u00b0 with significant shift",
          "contrast": "600:1 - 1000:1",
          "color_accuracy": "Fair",
          "response_time": "1-5 ms",
          "best_for": "Budget single-operator stations, non-critical display",
          "weakness": "Poor viewing angles, color accuracy",
          "note": "Lowest cost, acceptable only for direct front viewing"
        }
      ]
    },
    "5_mounting_design": {
      "standard": "VESA FDMI / ISO 11064-5",
      "principle": "Mounting must support weight safely and position screen ergonomically",
      "vesa_classes": [
        {
          "class": "MIS-B",
          "pattern_mm": "50x20",
          "screw": "M4",
          "max_weight_kg": 2,
          "typical_size": "< 12 inch"
        },
        {
          "class": "MIS-C",
          "pattern_mm": "75x75",
          "screw": "M4",
          "max_weight_kg": 4.5,
          "typical_size": "12-22 inch"
        },
        {
          "class": "MIS-D",
          "pattern_mm": "100x100",
          "screw": "M4",
          "max_weight_kg": 8,
          "typical_size": "22-32 inch"
        },
        {
          "class": "MIS-E",
          "pattern_mm": "200x100",
          "screw": "M4",
          "max_weight_kg": 23.7,
