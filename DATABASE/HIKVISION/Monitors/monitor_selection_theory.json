        {
          "class": "MIS-F",
          "pattern_mm": "200x200 to 800x400",
          "screw": "M6/M8",
          "max_weight_kg": 50,
          "typical_size": "43-90+ inch"
        }
      ],
      "ergonomic_placement": {
        "standard": "ISO 11064-5:2008",
        "screen_center_height_mm": {
          "min": 1000,
          "max": 1200,
          "note": "Above finished floor, seated operator"
        },
        "tilt_angle_deg": {
          "min": 0,
          "max": 35,
          "recommended": "10-20 backward from vertical"
        },
        "horizontal_viewing_arc": {
          "max_deg": 95,
          "note": "Total arc for multi-monitor setups per operator"
        }
      }
    },
    "6_reliability_selection": {
      "standard": "IEC 62368-1 / Manufacturer",
      "principle": "Operating hours rating must match deployment duty cycle",
      "duty_cycles": [
        {
          "classification": "7x24",
          "hours_per_year": 8760,
          "application": "Surveillance, control room, NOC/SOC, critical infrastructure",
          "min_backlight_life_hrs": 50000
        },
        {
          "classification": "7x16",
          "hours_per_year": 5840,
          "application": "Office surveillance, staffed control rooms",
          "min_backlight_life_hrs": 30000
        },
        {
          "classification": "7x12",
          "hours_per_year": 4380,
          "application": "Retail, reception, general display",
          "min_backlight_life_hrs": 30000
        },
        {
          "classification": "5x8",
          "hours_per_year": 2080,
          "application": "Standard office, meeting room",
          "min_backlight_life_hrs": 20000
        }
      ],
      "note": "Using a 7x12 rated monitor in 7x24 operation voids warranty and accelerates backlight degradation"
    },
    "7_power_infrastructure": {
      "standard": "IEC 60364 / NEC",
      "principle": "Electrical design must safely support all monitors with margin",
      "formulas": {
        "circuit_capacity": "Total_load = Sum(monitor_watts) \u00d7 1.25 safety_factor",
        "max_monitors_per_circuit": {
          "230V_16A": "Available_watts = 16 \u00d7 230 \u00d7 0.8 = 2944W",
          "120V_20A": "Available_watts = 20 \u00d7 120 \u00d7 0.8 = 1920W"
        },
        "heat_dissipation": "Q = Power_consumption \u00d7 3.412 BTU/hr per watt",
        "cooling_load": "Each monitor adds its full wattage as heat to room HVAC load"
      },
      "ups_sizing": {
        "formula": "UPS_VA = Sum(monitor_watts) / power_factor \u00d7 runtime_factor",
        "typical_power_factor": 0.7,
        "recommended_runtime_min": 15,
        "note": "Critical surveillance monitors should be on UPS with minimum 15 min runtime"
      }
    },
    "8_cable_infrastructure": {
      "standard": "HDMI Spec / DisplayPort Spec / BS EN 50173",
      "principle": "Cable type and length must match resolution and distance requirements",
      "max_passive_cable_length": [
        {
          "interface": "VGA",
          "max_length_m": 15,
          "recommended_m": 10,
          "note": "Quality degrades with length, use booster beyond 15m"
        },
        {
          "interface": "HDMI 1.4 (1080p)",
          "max_length_m": 15,
          "recommended_m": 10,
          "note": "Use active cable or extender beyond 15m"
        },
        {
          "interface": "HDMI 2.0 (4K@60Hz)",
          "max_length_m": 5,
          "recommended_m": 3,
          "note": "Use fiber HDMI or HDBaseT beyond 5m"
        },
        {
          "interface": "DisplayPort 1.2 (4K@60Hz)",
          "max_length_m": 3,
          "recommended_m": 2,
          "note": "Use DP fiber or extender beyond 3m"
        },
        {
          "interface": "HDBaseT (Cat6a)",
          "max_length_m": 100,
          "recommended_m": 80,
          "note": "Requires HDBaseT transmitter/receiver pair"
        },
        {
          "interface": "HDMI over Fiber",
          "max_length_m": 300,
          "recommended_m": 200,
          "note": "For long-run installations"
        }
      ]
    },
