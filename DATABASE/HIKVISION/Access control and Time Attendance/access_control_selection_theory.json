{
  "database_info": {
    "name": "Access Control Selection Theory - Standards Based",
    "version": "1.0",
    "purpose": "Engineering design tool for access control system selection",
    "last_updated": "2026-04-05"
  },
  "selection_criteria": {
    "1_authentication_method_selection": {
      "standard": "EN 60839-11-1 / Application Security Level",
      "principle": "Authentication method is selected based on required security level",
      "methods": [
        {
          "method": "Card Only (Mifare)",
          "security_level": "Low-Medium",
          "speed": "< 0.5s",
          "cost": "Low",
          "example_models": "DS-K1801M, DS-K1T801E, DS-K1T802M",
          "best_for": "General office, parking, building entry",
          "standard_note": "EN 60839-11-1 Grade 1-2"
        },
        {
          "method": "Card + PIN (Keypad)",
          "security_level": "Medium",
          "speed": "2-5s",
          "cost": "Low",
          "example_models": "DS-K1801MK, DS-K1101MK, DS-K1104MK",
          "best_for": "Server rooms, restricted areas, two-factor auth",
          "standard_note": "EN 60839-11-1 Grade 2-3"
        },
        {
          "method": "Fingerprint",
          "security_level": "Medium-High",
          "speed": "< 1s",
          "cost": "Medium",
          "example_models": "DS-K1A8503MF, DS-K1T8003MF, DS-K1109DKB",
          "best_for": "Time attendance, medium-security access",
          "standard_note": "FAR < 0.001%, FRR < 1%"
        },
        {
          "method": "Face Recognition",
          "security_level": "High",
          "speed": "< 0.2s",
          "cost": "Medium-High",
          "example_models": "DS-K1T341AM, DS-K1T342MFWX, DS-K1T502DBWX",
          "best_for": "Touchless entry, high-traffic areas, executive areas",
          "standard_note": "Deep learning, >99% accuracy, mask detection"
        },
        {
          "method": "Face + Fingerprint + Card",
          "security_level": "Very High",
          "speed": "1-3s",
          "cost": "High",
          "example_models": "DS-K1T341AMF, DS-K1T342MFWX, DS-K1T502DBFWX",
          "best_for": "High-security zones, multi-factor authentication",
          "standard_note": "EN 60839-11-1 Grade 3-4"
        },
        {
          "method": "QR Code",
          "security_level": "Low",
          "speed": "< 1s",
          "cost": "Medium",
          "example_models": "DS-K1T344MBWX-QRE1, DS-K1109DKFB-QR",
          "best_for": "Visitor management, temporary access, events"
        }
      ]
    },
    "2_controller_selection": {
      "standard": "EN 60839-11-1 / System Architecture",
      "principle": "Controller type and capacity is determined by number of doors and required features",
      "comparison": [
        {
          "series": "K2800 Value (DS-K2802/2804)",
          "doors": "2 or 4",
          "architecture": "Standalone + TCP/IP",
          "readers": "Wiegand only",
          "cards": 10000,
          "events": 50000,
          "best_for": "Small installations, basic access control",
          "note": "Budget option, proven reliable"
        },
        {
          "series": "K2600 Pro (DS-K2604T)",
          "doors": 4,
          "architecture": "Multi-ID + TCP/IP + RS-485",
          "readers": "4 Wiegand + 8 RS-485",
          "cards": "Large",
          "events": "Large",
          "best_for": "Multi-ID (face/fingerprint/card/QR/PIN), advanced features",
          "note": "Main board only, needs enclosure"
        },
        {
          "series": "K2600X Pro (DS-K2621X/2622X/2624X)",
          "doors": "1/2/4",
          "architecture": "Pro controller + TCP/IP",
          "readers": "Multiple",
          "cards": "Large",
          "events": "Large",
          "best_for": "Professional installations, enterprise",
          "note": "Latest generation controllers"
        }
      ],
      "sizing_formula": {
        "controllers_needed": "ceiling(total_doors / doors_per_controller)",
        "example": "12 doors \u00f7 4 doors/controller = 3x DS-K2804 or 3x DS-K2624X"
      }
    },
    "3_card_reader_selection": {
      "standard": "Manufacturer / Installation Environment",
      "principle": "Reader type is selected based on location, weather, and security level",
      "series_comparison": [
        {
          "series": "1801 (Slim)",
          "material": "PC+ABS",
          "ip": "IP64",
          "ik": null,
          "mounting": "Surface",
          "best_for": "Indoor, clean environment, basic access"
        },
        {
          "series": "1101 (Standard)",
          "material": "PC+ABS",
          "ip": "IP64",
          "ik": null,
          "mounting": "120 gang box",
          "best_for": "Indoor/sheltered, standard office"
        },
        {
          "series": "1102 (Waterproof)",
          "material": "PC+ABS",
          "ip": "IP65",
          "ik": null,
          "mounting": "Gang box",
          "best_for": "Semi-outdoor, rain-exposed areas"
        },
        {
          "series": "1103 (Enhanced)",
          "material": "PC+ABS",
          "ip": "IP65",
          "ik": null,
          "mounting": "Gang box",
          "best_for": "Outdoor, moderate weather"
        },
        {
          "series": "1104 (Vandal-proof)",
          "material": "PC+Zinc-alloy",
          "ip": "IP65",
          "ik": "IK10",
          "mounting": "86 & 120 gang box",
          "best_for": "Public areas, parking, industrial, vandalism risk"
        }
      ],
      "card_technology": {
        "mifare_13_56mhz": {
          "range_mm": 50,
          "security": "Encrypted",
          "note": "Standard for Hikvision systems. M suffix in model names."
        },
        "em_125khz": {
          "range_mm": 100,
          "security": "Unencrypted",
          "note": "Legacy. E suffix. Not recommended for new installations."
        }
      }
    },
    "4_door_lock_selection": {
      "standard": "EN 14846 / EN 12209 / Fire Code",
      "principle": "Lock type depends on door type, fail-safe/fail-secure requirement, and fire code",
      "types": [
        {
          "type": "Electromagnetic Lock (Mag Lock)",
          "models": "DS-K4H258S (280kg), DS-K4H450S (450kg)",
          "fail_mode": "Fail-safe (unlocks on power loss)",
          "best_for": "Glass doors, fire exits (with fire alarm release), clean rooms",
          "requires": "L/Z bracket (DS-K4H255-LZ), door closer",
          "standard": "Must release on fire alarm per NFPA 101 / EN 1125"
        },
        {
          "type": "Electric Strike",
          "models": "DS-K4DC103, DS-K4DC105",
          "fail_mode": "Configurable (fail-safe or fail-secure)",
          "best_for": "Standard wooden/metal doors with mechanical lock",
          "requires": "Compatible door frame cutout",
          "standard": "EN 14846 for lock grading"
        },
        {
          "type": "Electric Bolt Lock",
          "models": "Various",
          "fail_mode": "Fail-secure (locks on power loss)",
          "best_for": "High-security doors, server rooms",
          "standard": "Not for fire exits unless override provided"
        }
      ],
      "holding_force_guideline": {
        "280kg_600lb": "Standard single doors, interior applications",
        "450kg_1000lb": "Heavy doors, high-security, exterior doors",
        "note": "Holding force must exceed expected forced-entry attempt. 280kg is standard minimum."
      },
      "fire_safety": {
        "standard": "NFPA 101 / EN 1125 / Local Fire Code",
        "requirement": "All electrically locked doors on fire egress routes MUST release on fire alarm activation or power loss",
        "implementation": "Mag locks (fail-safe) on fire exits. Wire mag lock power through fire alarm relay for automatic release."
      }
    },
    "5_wiring_infrastructure": {
      "standard": "EN 50173 / TIA-568 / Manufacturer",
      "principle": "Cable type and distance must match communication protocol",
      "cable_specifications": [
        {
          "protocol": "TCP/IP (Ethernet)",
          "cable": "Cat5e/Cat6 UTP/STP",
          "max_distance_m": 100,
          "connector": "RJ45",
          "note": "Controller to switch/network"
        },
        {
          "protocol": "RS-485",
          "cable": "Shielded twisted pair 0.5mm\u00b2",
          "max_distance_m": 1200,
          "connector": "Terminal block",
          "note": "Controller to RS-485 readers. 120\u03a9 termination at ends."
        },
        {
          "protocol": "Wiegand (W26/W34)",
          "cable": "Multi-core shielded 0.5mm\u00b2",
          "max_distance_m": 100,
          "connector": "Terminal block",
          "note": "Controller to Wiegand readers. Keep runs short for reliability."
        },
        {
          "protocol": "Door lock power",
          "cable": "2-core 1.0mm\u00b2 minimum",
          "max_distance_m": 50,
          "connector": "Terminal block",
          "note": "12/24VDC to lock. Calculate voltage drop for long runs."
        },
        {
          "protocol": "Door contact / REX",
          "cable": "2-core 0.5mm\u00b2",
          "max_distance_m": 50,
          "connector": "Terminal block",
          "note": "Magnetic contact and request-to-exit button"
        }
      ],
      "voltage_drop_formula": {
        "formula": "V_drop = (2 \u00d7 length_m \u00d7 current_A \u00d7 resistivity) / cross_section_mm\u00b2",
        "copper_resistivity": "0.0175 \u03a9\u00b7mm\u00b2/m",
        "max_acceptable_drop": "10% of supply voltage",
        "note": "For mag locks drawing 0.5A at 12V over 30m with 1.0mm\u00b2 cable: V_drop = 2\u00d730\u00d70.5\u00d70.0175/1.0 = 0.525V (4.4%) \u2014 acceptable"
      }
    },
    "6_power_supply_design": {
      "standard": "IEC 60364 / EN 54 (fire integration)",
      "principle": "Power supply must support all devices with battery backup for security",
      "sizing": {
        "controller_w": 3.5,
        "reader_w": 6,
        "mag_lock_w": {
          "280kg": 7.2,
          "450kg": 10.8
        },
        "electric_strike_w": 3.6,
        "face_terminal_w": 12,
        "formula": "Total_W = sum(all_device_watts) \u00d7 1.25 safety factor",
        "battery_backup_hours": {
          "minimum": 4,
          "recommended": 8,
          "note": "Per EN 60839-11-1 Grade 3+"
        }
      },
      "hikvision_psu": [
        {
          "model": "DS-K7P08",
          "output": "12VDC",
          "note": "Basic power supply for single door"
        },
        {
          "model": "DS-K7M-AW24",
          "output": "12/24VDC",
          "note": "Multi-output for door locks and controllers"
        }
      ]
    },
    "7_system_capacity_planning": {
      "standard": "Application Design",
      "principle": "System must be sized for current needs plus expansion",
      "capacity_tiers": [
        {
          "size": "Small (1-4 doors)",
          "controller": "1x DS-K2804 or DS-K2624X",
          "readers": "4-8",
          "cards": "< 1,000",
          "software": "iVMS-4200 (free)"
        },
        {
          "size": "Medium (5-20 doors)",
          "controller": "2-5x DS-K2804 or DS-K2624X",
          "readers": "10-40",
          "cards": "1,000-10,000",
          "software": "HikCentral Professional"
        },
        {
          "size": "Large (20-100 doors)",
          "controller": "5-25x controllers",
          "readers": "40-200",
          "cards": "10,000+",
          "software": "HikCentral Enterprise"
        },
        {
          "size": "Enterprise (100+ doors)",
          "controller": "25+ controllers",
          "readers": "200+",
          "cards": "50,000+",
          "software": "HikCentral Enterprise + integration"
        }
      ],
      "expansion_rule": "Design for 20-30% spare capacity in controllers, card database, and cable infrastructure"
    },
    "8_compliance_standards": {
      "principle": "Access control systems must meet security grading, fire safety, and data protection standards",
      "standards": [
        {
          "standard": "EN 60839-11-1:2013",
          "scope": "Alarm and access control systems \u2014 Security grading (Grade 1-4)"
        },
        {
          "standard": "EN 50133-1:1996+A1:2002",
          "scope": "Access control systems for buildings \u2014 System requirements"
        },
        {
          "standard": "EN 14846:2008",
          "scope": "Building hardware \u2014 Lock grading"
        },
        {
          "standard": "EN 1125:2008",
          "scope": "Panic exit devices (fire egress)"
        },
        {
          "standard": "EN 179:2008",
          "scope": "Emergency exit devices"
        },
        {
          "standard": "NFPA 101",
          "scope": "Life Safety Code \u2014 door locking and egress requirements"
        },
        {
          "standard": "IEC 62368-1",
          "scope": "Safety of electronic access control equipment"
        },
        {
          "standard": "GDPR / Data Protection",
          "scope": "Biometric data (fingerprint/face) classified as sensitive personal data \u2014 requires consent and secure storage"
        },
        {
          "standard": "ADA / Accessibility",
          "scope": "Reader mounting height 900-1200mm AFF, accessible operation"
        }
      ]
    },
    "9_mounting_and_installation": {
      "standard": "ADA / EN 50133 / Best Practice",
      "principle": "Device mounting must be ergonomic, accessible, and secure",
      "mounting_heights_mm": {
        "card_reader": {
          "center": 1200,
          "range": "900-1400",
          "standard": "ADA / EN 50133"
        },
        "fingerprint_reader": {
          "center": 1100,
          "range": "1000-1200"
        },
        "face_recognition_terminal": {
          "center": 1400,
          "range": "1300-1500",
          "note": "Must accommodate standing adult face position"
        },
        "request_to_exit_button": {
          "center": 1200,
          "range": "900-1400"
        },
        "door_magnetic_contact": {
          "position": "Top of door frame, hinge side"
        }
      },
      "gang_box_types": {
        "86_gang_box": "Standard European/Asian flush mount box",
        "120_gang_box": "Standard US single-gang box",
        "surface_mount": "When flush mounting is not possible"
      }
    },
    "10_time_attendance_design": {
      "standard": "Labor Law / Application",
      "principle": "Time attendance terminals must capture accurate clock-in/out with audit trail",
      "terminal_selection": {
        "basic_card": {
          "models": "DS-K1T801E, DS-K1T802M",
          "pros": "Fast, simple, low cost",
          "cons": "Buddy punching possible (card sharing)"
        },
        "fingerprint": {
          "models": "DS-K1A8503MF, DS-K1T8003MF",
          "pros": "No buddy punching, proven technology",
          "cons": "Dirty/wet fingers may fail"
        },
        "face_recognition": {
          "models": "DS-K1T341AM, DS-K1T342MFWX",
          "pros": "Touchless, no buddy punching, fast, hygienic",
          "cons": "Higher cost, lighting sensitivity"
        },
        "multi_mode": {
          "models": "DS-K1T341AMF, DS-K1T502DBFWX",
          "pros": "Fallback options if primary method fails",
          "cons": "Highest cost"
        }
      },
      "capacity_planning": {
        "rule": "1 terminal per 50-100 employees for smooth peak-hour throughput",
        "peak_calculation": "If 200 employees arrive within 30 min, face recognition at 20 people/min = need 1 terminal with some queuing, or 2 for no queue"
      }
    }
  }
}