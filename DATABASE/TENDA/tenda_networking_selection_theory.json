        },
        "TFC300A/B": {
          "speed": "Gigabit",
          "price": "$22-25",
          "use": "Gigabit fiber link"
        }
      },
      "note": "Always buy in A+B pairs (one for each end of fiber link)"
    },
    "9_managed_vs_unmanaged": {
      "principle": "Managed switches essential for VLAN, QoS, and monitoring in professional installations",
      "tenda_tiers": [
        {
          "tier": "Unmanaged",
          "models": "S105-S108, SG105M-SG108M, TEF1016D, TEG1024G",
          "features": "Plug-and-play only",
          "best_for": "Simple small networks"
        },
        {
          "tier": "Smart L2",
          "models": "i24-i29, TEG2216D-TEG2228P",
          "features": "VLAN, QoS, LACP, IGMP, SNMP",
          "best_for": "Camera networks needing VLAN isolation"
