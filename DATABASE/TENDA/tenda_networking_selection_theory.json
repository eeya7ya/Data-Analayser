  "selection_criteria": {
    "1_brand_positioning": {
      "principle": "Tenda = budget/SMB networking. HPE Aruba = enterprise managed networking.",
      "guide": [
        {
          "brand": "Tenda",
          "tier": "Budget/SMB",
          "managed": "Unmanaged or basic L2",
          "support": "Limited",
          "best_for": "Small office, residential, cost-sensitive projects, basic camera PoE",
          "warranty": "Standard"
        },
        {
          "brand": "HPE Aruba Instant On",
          "tier": "Enterprise",
          "managed": "L2+/L3, cloud managed",
          "support": "HPE enterprise support",
          "best_for": "Corporate, hotel, campus, managed Wi-Fi, VLAN networks",
          "warranty": "Limited Lifetime"
        }
      ]
    },
    "2_switch_selection_by_camera_count": {
      "principle": "Match switch ports, PoE budget, and speed to camera requirements",
      "guide": [
        {
          "cameras": "1-4",
          "switch": "TEF1105P-4-63W ($15.5) or TEG1105P-4-63W ($24)",
          "notes": "63W budget sufficient for 4 cameras"
        },
        {
          "cameras": "5-8",
          "switch": "TEF1109P-8-102W ($29) or TEG1110PF-8-102W ($38)",
          "notes": "102W for 8\u00d7 PoE cameras"
        },
        {
          "cameras": "9-16",
          "switch": "TEF1118P-16-150W ($63) or TEG1116P-16-150W ($85)",
          "notes": "150W budget"
        },
        {
          "cameras": "17-24",
          "switch": "TEF1126P-24-250W ($85) or TEG1124P-24-250W ($120)",
          "notes": "250W for 24 cameras"
        },
        {
          "cameras": "24+ (high power)",
          "switch": "TEG1126P-24-410W ($185)",
          "notes": "410W for PTZ/high-power cameras"
        },
        {
          "cameras": "Enterprise/managed",
          "switch": "HPE Aruba JL683A ($275) or TEG2228P ($175)",
          "notes": "VLAN, QoS, SNMP monitoring"
        }
      ]
    },
    "3_100mbps_vs_gigabit_switches": {
      "principle": "Fast Ethernet (TEF) for budget 2MP cameras. Gigabit (TEG) for 4MP+ and future-proof.",
      "comparison": {
        "tef_fast_ethernet": {
          "speed": "10/100Mbps",
          "prefix": "TEF",
          "best_for": "2MP cameras, basic IP phones",
          "cost": "Lower"
        },
        "teg_gigabit": {
          "speed": "10/100/1000Mbps",
          "prefix": "TEG",
          "best_for": "4MP+ cameras, 4K NVR, future-proof",
          "cost": "15-30% more"
        }
      }
    },
    "4_router_selection": {
      "principle": "Router tier based on users and coverage",
      "guide": [
        {
          "tier": "Basic (1-5 users)",
          "models": "N301 ($8), F3 ($9.5)",
          "wifi": "300Mbps 2.4GHz"
        },
        {
          "tier": "Standard (5-15 users)",
          "models": "AC5 ($15), AC8 ($19), A18 ($16.5)",
          "wifi": "AC1200-1900"
        },
        {
          "tier": "Wi-Fi 6 (10-30 users)",
          "models": "TX2Pro ($30), TX9 ($40), TX12 Pro ($52)",
          "wifi": "AX1500-3000"
        },
        {
          "tier": "Wi-Fi 6E (20-50 users)",
          "models": "TE6L Pro ($62)",
          "wifi": "6GHz tri-band"
        },
        {
          "tier": "Mesh (whole home/office)",
          "models": "MW6 2-pack ($45), MW5G 3-pack ($60)",
          "coverage": "250-350m\u00b2"
        }
      ]
    },
    "5_enterprise_wifi_aruba": {
      "principle": "HPE Aruba APs for professional Wi-Fi with central cloud management",
      "models": [
