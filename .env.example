# === MagicTech Quotation Designer — Environment ===

# ---------------------------------------------------------------------------
# Supabase Postgres (required)
# ---------------------------------------------------------------------------
# On Vercel: the easiest path is to install the **Supabase integration**
# (Vercel → Integrations → Supabase → link to this project). It auto-injects
# POSTGRES_URL / POSTGRES_URL_NON_POOLING / SUPABASE_URL / SUPABASE_ANON_KEY /
# SUPABASE_SERVICE_ROLE_KEY for all environments — no manual copying needed.
#
# For LOCAL development: set DATABASE_URL (or POSTGRES_URL) manually. Use the
# Supabase **Transaction Pooler** (Supavisor) URI from:
#   Supabase Dashboard → Project Settings → Database → Connection string
#     → "Transaction pooler"  (IPv4 compatible, port 6543)
#
# Format:
#   postgres://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# Resolution order (first non-empty wins):
#   DATABASE_URL → POSTGRES_URL → POSTGRES_PRISMA_URL → POSTGRES_URL_NON_POOLING
#
# IMPORTANT: Do NOT commit this value. Set it in Vercel → Project Settings →
# Environment Variables, marked as "Sensitive" for all environments.
DATABASE_URL=
# Alternatively (Vercel integration injects these automatically):
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Auto-injected by the Supabase→Vercel integration. Only needed if you later
# integrate the Supabase JS SDK for client-side Realtime / Storage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Privileged server-side key. NEVER expose this to the browser.
# Not required by the current code path (the app uses direct Postgres).
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# App auth
# ---------------------------------------------------------------------------
# JWT signing secret. MUST be a long (>=32 chars) random string.
# Generate with:  openssl rand -base64 48
AUTH_SECRET=change-me-to-a-long-random-string

# Default admin credentials used on first boot. CHANGE IMMEDIATELY after
# first login from the /admin page.
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin123

# ---------------------------------------------------------------------------
# Groq (required for the AI designer)
# ---------------------------------------------------------------------------
# Free tier key: https://console.groq.com/keys
GROQ_API_KEY=

# Groq models
# Design model — pick any chat model from the GROQ_CHAT_MODELS catalog:
#   llama-3.3-70b-versatile (default)  |  llama-3.1-8b-instant
#   meta-llama/llama-4-scout-17b-16e-instruct
#   moonshotai/kimi-k2-instruct         |  moonshotai/kimi-k2-instruct-0905
#   openai/gpt-oss-120b                 |  openai/gpt-oss-20b
#   qwen/qwen3-32b
GROQ_DESIGN_MODEL=llama-3.3-70b-versatile
# Agentic model with built-in web search for deep-dive fallbacks
#   groq/compound (default)  |  groq/compound-mini
GROQ_WEB_MODEL=groq/compound

# ---------------------------------------------------------------------------
# GitHub catalog
# ---------------------------------------------------------------------------
# GitHub repo (owner/name) that hosts the DATABASE/ folder.
# The app fetches JSON files from raw.githubusercontent.com of this repo.
GITHUB_REPO=eeya7ya/Data-Analayser
GITHUB_BRANCH=claude/migrate-neon-to-supabase-a3m4d

# Logo on GitHub (raw URL). Falls back to /logo-placeholder.svg if empty.
COMPANY_LOGO_URL=
