# === MagicTech Quotation Designer — Environment ===

# Serverless Postgres (Neon / Vercel Postgres). Required.
# Example: postgres://user:password@ep-xxxx.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# JWT signing secret. Any long random string.
AUTH_SECRET=change-me-to-a-long-random-string

# Default admin credentials used on first boot (change after first login).
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin123

# Groq API key (free tier works). https://console.groq.com/keys
GROQ_API_KEY=

# Groq models
GROQ_DESIGN_MODEL=llama-3.3-70b-versatile
# Agentic model with built-in web search for deep-dive fallbacks
GROQ_WEB_MODEL=compound-beta

# GitHub repo (owner/name) that hosts the DATABASE/ folder.
# The app fetches JSON files from raw.githubusercontent.com of this repo.
GITHUB_REPO=eeya7ya/Data-Analayser
GITHUB_BRANCH=claude/designer-quotation-search-jcWnF

# Logo on GitHub (raw URL). Falls back to /logo-placeholder.svg if empty.
COMPANY_LOGO_URL=
